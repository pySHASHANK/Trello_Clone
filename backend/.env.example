# This file is an example of what your `.env` file should look like.
# DO NOT put real passwords here! Copy this file, rename it to just `.env`, and fill in the blanks.

PORT=5000

# The Prisma Database Connection String format:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?schema=public

# Example using a local PostgreSQL setup on your computer:
# DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:5432/trelloclone?schema=public"

# Example using a Neon/Supabase cloud database:
# DATABASE_URL="postgresql://myuser:mypassword@db.neon.tech/neondb?sslmode=require"

DATABASE_URL="YOUR_DATABASE_URL_GOES_HERE"
